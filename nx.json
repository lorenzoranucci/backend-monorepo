{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "affected": {
    "defaultBase": "main"
  },
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "production": [
      "default"
    ],
    "sharedGlobals": [
      "{workspaceRoot}/go.mod"
    ]
  },
  "plugins": [
    {
      "plugin": "@nx-go/nx-go",
      "options": {
        "buildTargetName": "build",
        "serveTargetName": "serve",
        "testTargetName": "test",
        "lintTargetName": "lint",
        "tidyTargetName": "tidy",
        "generateTargetName": "generate"
      }
    }
  ],
  "analytics": false
}