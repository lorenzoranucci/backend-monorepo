{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "affected": {
    "defaultBase": "main"
  },
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "production": [
      "default"
    ],
    "sharedGlobals": [
      "{workspaceRoot}/go.mod"
    ]
  },
  "plugins": [
    {
      "plugin": "@nx-go/nx-go"
    }
  ],
  "targetDefaults": {
    "lint": {
      "executor": "@nx-go/nx-go:lint",
      "options": {
        "linter": "golangci-lint run"
      }
    },
    "test": {
      "executor": "@nx-go/nx-go:test",
      "options": {
        "race": true
      }
    }
  },
  "pluginsConfig": {
    "@nx/js": {
      "projectsAffectedByDependencyUpdates": []
    }
  },
  "analytics": false
}
