{
  "name": "quote-domain/hello-world-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "quote-domain/hello-world-api",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx-go/nx-go:build",
      "options": {
        "main": "main.go"
      },
      "cache": true,
      "inputs": ["golang"],
      "outputs": ["{workspaceRoot}/dist/{projectRoot}*"]
    },
    "serve": {
      "executor": "@nx-go/nx-go:serve",
      "options": {
        "main": "main.go"
      },
      "inputs": ["golang"],
      "continuous": true
    },
    "test": {
      "executor": "@nx-go/nx-go:test",
      "cache": true,
      "inputs": ["golang"]
    },
    "lint": {
      "executor": "@nx-go/nx-go:lint",
      "cache": true,
      "inputs": ["golang"]
    },
    "tidy": {
      "executor": "@nx-go/nx-go:tidy",
      "cache": true,
      "inputs": ["golang"],
      "outputs": ["{projectRoot}/go.mod", "{projectRoot}/go.sum"]
    }
  }
}
